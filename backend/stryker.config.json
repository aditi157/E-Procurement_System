{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "jest",

  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.js"
  },

  "mutate": [
    "src/controllers/**/*.js"
  ],

  "timeoutMS": 15000,
  "timeoutFactor": 3,

  "maxConcurrentTestRunners": 2,

  "coverageAnalysis": "off",

  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],

  "testRunnerNodeArgs": [
    "--experimental-vm-modules"
  ]
}